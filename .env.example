# DUKA POS Environment Variables
# Copy to .env and fill in your values

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# M-Pesa (stored in Supabase app_settings, not exposed to client)
# Configure via Admin > Settings in the app

# Resend (for email receipts & daily summaries)
# Set as Supabase Edge Function secret
# RESEND_API_KEY=re_xxxxxxxxxxxx
